<% layout("/layouts/boilerPlate") %>

<div class="row">
  <div class="col-8 offset-2">

    <h3>Create New Listing</h3>

    <form
      action="/listings"
      method="POST"
      enctype="multipart/form-data"
      class="needs-validation"
      novalidate
    >
      <div class="mb-3">
        <lable for="title" class = "form-label">Title</lable>

        <input 
          name="listing[title]" 
          placeholder="enter Catchy title" 
          type="text" 
          class="form-control" required
         />
        <div class="valid-feedback"> Title look good</div>
      </div>
     
      <div class="mb-3">
        <label for="description"class = "form-label"> Description : </label>
          <textarea
          name="listing[description]"
          placeholder="enter description"
          class="form-control"
          required
      ></textarea>
      <div class="invalid-feedback"> Please enter the short Description </div>
      </div>

      <div class="mb-3">
        <label for="image" class = "form-label">  upload image : </label>
          
          <input
            name="listing[image]"
            placeholder="enter image URL/Link"
            type="file"
            class="form-control"
          />
      </div>
    <div class="row">
      <div class="mb-3 col-md-4">
        <label for="price"class = "form-label">  Price: </label>
         <input 
            name="listing[price]" 
            class="form-control" 
            placeholder="1233" 
            type="number"
            required
             />
             <div class="invalid-feedback"> Price should be valid</div>
        </div>
      
  
        <div class="mb-3 col-8">
          <label for="country"class = "form-label">  country: </label>
          <input 
            name="listing[country]" 
            class="form-control" 
            placeholder="India"
             type="text"
             required
             />
            <div class="invalid-feedback">country name should be valid</div>
        </div>
      </div>
        
      <div class="mb-3">
        <label for="location"class = "form-label">  Location: </label>
          <input
        name="listing[location]"
        placeholder="Jaipur,Rajsthan"
        type="text"class="form-control"
        required
      />
      <div class="invalid-feedback"> Location should be valid</div>
      <div class="mb-3">
        <label for="category" class="form-label">Category</label>

      <select name="listing[category]" id="category" class="form-select" required>
        <option value="">Select Category</option>
        <option value="Trending">Trending</option>
        <option value="Rooms">Rooms</option>
        <option value="Mountain">Mountain</option>
        <option value="Castles">Castles</option>
        <option value="Arctic">Arctic</option>
        <option value="Camping">Camping</option>
        <option value="Iconic Cities">Iconic Cities</option>
        <option value="Farms">Farms</option>
        <option value="Forest">Forest</option>
        <option value="Beach">Beach</option>
        <option value="Amazing Pools">Amazing Pools</option>
        </select>
      </div>

    
      <button class="btn btn-dark add-btn mt-3">Add</button>
      <br><br>
    </form>
    </div>
  </div>
</div>